{
  "name": "@devscholar/wacl-tk-demos",
  "version": "0.0.1",
  "description": "Demos that compose wacl-tk's Tcl/Tk with em-x11's Xlib surface.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm run build:native && pnpm run build:web",
    "build:native": "emcmake cmake -S . -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build -j",
    "build:native:debug": "emcmake cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build -j",
    "build:web": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf build dist",
    "clean:all": "rimraf build dist node_modules"
  },
  "devDependencies": {
    "@types/emscripten": "^1.39.10",
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
